# Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# ===== FLASK CONFIGURATION =====
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-very-long-random-secret-key-change-this-in-production-min-32-chars

# ===== DATABASE CONFIGURATION =====
# For development use SQLite (default: sqlite:///instance/messages.db)
# For production use PostgreSQL, MySQL, etc.
DATABASE_URL=sqlite:///instance/messages.db

# ===== SMTP MAIL CONFIGURATION =====
# Gmail Example (requires App Password, not regular password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Alternative: For other SMTP providers
# MAIL_SERVER=smtp.your-provider.com
# MAIL_PORT=587 (or 465 for SSL)
# MAIL_USERNAME=your-username
# MAIL_PASSWORD=your-password

# Where form submissions are sent
CONTACT_MAIL=info@qualityprint.at

# ===== SEO & COMPANY CONFIGURATION =====
SITE_URL=https://qualityprint.at
COMPANY_NAME=Quality Print
COMPANY_DESCRIPTION=Professionelle Druckdienstleistungen für Premium-Qualität
COMPANY_PHONE=+43 512 123456
COMPANY_EMAIL=kontakt@qualityprint.at
COMPANY_ADDRESS=Mustergasse 123, 6020 Innsbruck

# ===== SECURITY SETTINGS =====
# Set to True in production
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ===== LOGGING =====
# Logs are saved to /logs directory
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== PRODUCTION ONLY =====
# Uncomment for production deployments
# WORKERS=4
# TIMEOUT=120
# BIND=0.0.0.0:5000

