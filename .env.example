# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# SMTP Configuration (Gmail Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Contact Email (where form submissions go)
CONTACT_MAIL=info@qualityprint.de

# Database URL (optional, defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost/qualityprint

# Frontend Settings (optional)
COMPANY_NAME=Quality Print
COMPANY_PHONE=+49 (0) 30 12345678
COMPANY_EMAIL=info@qualityprint.de
COMPANY_ADDRESS=Mustergasse 123, 10115 Berlin
